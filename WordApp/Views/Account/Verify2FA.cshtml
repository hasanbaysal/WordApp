@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>İki Adımlı Doğrulama - WordApp</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        :root {
            --bg-color: #0d0f12;
            --card-bg: rgba(22, 26, 33, 0.7);
            --border-color: rgba(255, 255, 255, 0.08);
            --text-color: #f1f3f5;
            --text-muted: #868e96;
            --primary: #4f46e5;
            --primary-glow: rgba(79, 70, 229, 0.4);
            --success: #10b981;
            --error: #ef4444;
            --warning: #f59e0b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Outfit', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            position: relative;
        }

        /* Ambient glow background effects */
        body::before, body::after {
            content: "";
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, var(--primary-glow) 0%, transparent 70%);
            z-index: -1;
            filter: blur(50px);
        }
        body::before {
            top: -10%;
            left: -10%;
        }
        body::after {
            bottom: -10%;
            right: -10%;
        }

        .login-container {
            width: 100%;
            max-width: 450px;
            padding: 20px;
        }

        .login-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 40px;
            backdrop-filter: blur(20px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
            text-align: center;
        }

        .brand i {
            font-size: 3rem;
            color: var(--warning);
            display: inline-block;
            margin-bottom: 10px;
            filter: drop-shadow(0 0 10px rgba(245, 158, 11, 0.4));
        }

        .brand h1 {
            font-size: 1.8rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, #fff 0%, var(--text-muted) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 5px;
        }

        .brand p {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 25px;
        }

        .form-group {
            margin-bottom: 24px;
            position: relative;
            text-align: left;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text-muted);
            text-align: center;
        }

        .code-input-wrapper {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
        }

        .code-input-char {
            width: 50px;
            height: 60px;
            font-size: 1.8rem;
            font-weight: 700;
            text-align: center;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            color: #fff;
            outline: none;
            transition: all 0.2s ease;
        }

        .code-input-char:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px var(--primary-glow);
            background: rgba(0, 0, 0, 0.4);
        }

        .timer-container {
            margin: 20px 0;
            font-size: 1rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .timer-value {
            font-weight: 700;
            color: var(--warning);
            font-size: 1.1rem;
        }

        .btn-submit {
            width: 100%;
            padding: 16px;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 12px var(--primary-glow);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-submit:hover:not(:disabled) {
            background: #4338ca;
            transform: translateY(-2px);
            box-shadow: 0 6px 18px var(--primary-glow);
        }

        .btn-submit:disabled {
            background: #2e3036;
            color: #5d616d;
            box-shadow: none;
            cursor: not-allowed;
        }

        .error-summary {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 12px;
            padding: 12px 16px;
            margin-bottom: 20px;
            color: var(--error);
            font-size: 0.9rem;
            text-align: left;
        }

        .back-link {
            display: inline-block;
            margin-top: 20px;
            color: var(--text-muted);
            font-size: 0.9rem;
            text-decoration: none;
            transition: color 0.2s ease;
        }

        .back-link:hover {
            color: var(--text-color);
        }

        /* Hidden standard input that we submit */
        #actual-code-input {
            display: none;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-card">
            <div class="brand">
                <i class="bi bi-shield-lock-fill"></i>
                <h1>İki Adımlı Doğrulama</h1>
                <p>E-posta adresinize gönderilen 5 haneli doğrulama kodunu girin.</p>
            </div>

            <form asp-action="Verify2FA" method="post" id="verifyForm">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="error-summary" asp-validation-summary="ModelOnly"></div>
                }

                <input type="hidden" name="code" id="actual-code-input" />

                <div class="form-group">
                    <label class="form-label">Doğrulama Kodu</label>
                    <div class="code-input-wrapper">
                        <input type="text" class="code-input-char" maxlength="1" pattern="[0-9]" required autocomplete="off" />
                        <input type="text" class="code-input-char" maxlength="1" pattern="[0-9]" required autocomplete="off" />
                        <input type="text" class="code-input-char" maxlength="1" pattern="[0-9]" required autocomplete="off" />
                        <input type="text" class="code-input-char" maxlength="1" pattern="[0-9]" required autocomplete="off" />
                        <input type="text" class="code-input-char" maxlength="1" pattern="[0-9]" required autocomplete="off" />
                    </div>
                </div>

                <div class="timer-container">
                    <i class="bi bi-clock-history"></i>
                    <span>Kalan Süre:</span>
                    <span class="timer-value" id="countdown">02:00</span>
                </div>

                <button type="submit" class="btn-submit" id="submitBtn">
                    Kodu Doğrula <i class="bi bi-check-circle"></i>
                </button>
            </form>

            <a asp-action="Login" class="back-link">
                <i class="bi bi-arrow-left"></i> Giriş ekranına geri dön
            </a>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const inputs = document.querySelectorAll(".code-input-char");
            const actualInput = document.getElementById("actual-code-input");
            const form = document.getElementById("verifyForm");
            const submitBtn = document.getElementById("submitBtn");

            // Focus on first input on load
            if (inputs.length > 0) {
                inputs[0].focus();
            }

            // Keyboard navigation and auto-focus for verification code boxes
            inputs.forEach((input, index) => {
                input.addEventListener("input", function (e) {
                    // Only allow numeric input
                    this.value = this.value.replace(/[^0-9]/g, "");

                    if (this.value.length === 1) {
                        if (index < inputs.length - 1) {
                            inputs[index + 1].focus();
                        }
                    }
                    updateActualCode();
                });

                input.addEventListener("keydown", function (e) {
                    if (e.key === "Backspace") {
                        if (this.value.length === 0 && index > 0) {
                            inputs[index - 1].focus();
                            inputs[index - 1].value = "";
                        } else {
                            this.value = "";
                        }
                        updateActualCode();
                        e.preventDefault();
                    } else if (e.key === "ArrowLeft" && index > 0) {
                        inputs[index - 1].focus();
                    } else if (e.key === "ArrowRight" && index < inputs.length - 1) {
                        inputs[index + 1].focus();
                    }
                });

                // Paste support
                input.addEventListener("paste", function (e) {
                    e.preventDefault();
                    const pastedData = (e.clipboardData || window.clipboardData).getData("text").trim();
                    if (/^\d{5}$/.test(pastedData)) {
                        inputs.forEach((inp, idx) => {
                            inp.value = pastedData[idx];
                        });
                        updateActualCode();
                        inputs[inputs.length - 1].focus();
                    }
                });
            });

            function updateActualCode() {
                let code = "";
                inputs.forEach(inp => {
                    code += inp.value;
                });
                actualInput.value = code;
            }

            // Form Submit validation
            form.addEventListener("submit", function (e) {
                updateActualCode();
                if (actualInput.value.length !== 5) {
                    e.preventDefault();
                    alert("Lütfen 5 haneli doğrulama kodunu eksiksiz girin.");
                }
            });

            // Countdown Timer (120 seconds = 2 minutes)
            let timeLeft = 120;
            const countdownEl = document.getElementById("countdown");

            const timerInterval = setInterval(function () {
                timeLeft--;
                
                const minutes = Math.floor(timeLeft / 60);
                const seconds = timeLeft % 60;
                
                const minutesStr = minutes < 10 ? "0" + minutes : minutes;
                const secondsStr = seconds < 10 ? "0" + seconds : seconds;
                
                countdownEl.textContent = `${minutesStr}:${secondsStr}`;

                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    countdownEl.textContent = "Süre Doldu!";
                    countdownEl.style.color = "var(--error)";
                    
                    // Disable inputs and button
                    inputs.forEach(inp => inp.disabled = true);
                    submitBtn.disabled = true;
                    
                    // Show message
                    const brandP = document.querySelector(".brand p");
                    if (brandP) {
                        brandP.textContent = "Doğrulama kodunun süresi doldu. Lütfen giriş ekranına dönüp tekrar deneyin.";
                        brandP.style.color = "var(--error)";
                    }
                }
            }, 1000);
        });
    </script>
</body>
</html>
