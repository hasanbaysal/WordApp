<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WordApp</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Custom site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WordApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark bg-transparent py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Words" asp-action="Index">
                    <i class="bi bi-translate brand-icon"></i>
                    <span class="brand-text">WordApp</span>
                </a>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="bi bi-list fs-2 text-white"></i>
                    </button>
                    
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1 mt-2 mt-lg-0">
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 rounded-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Words" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" asp-controller="Words" asp-action="Index">
                                    <i class="bi bi-grid-fill me-1"></i> Panel
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 rounded-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Words" && ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")" asp-controller="Words" asp-action="Create">
                                    <i class="bi bi-plus-circle-fill me-1"></i> Yeni Kelime
                                </a>
                            </li>
                        </ul>
                        <div class="d-flex align-items-center gap-3">
                            <span class="user-badge d-none d-md-flex align-items-center gap-2">
                                <i class="bi bi-person-circle text-primary"></i>
                                <span>@User.Identity.Name</span>
                            </span>
                            <a class="btn-logout d-flex align-items-center gap-1" asp-controller="Account" asp-action="Logout" title="Çıkış Yap">
                                <i class="bi bi-box-arrow-right"></i> Çıkış
                            </a>
                        </div>
                    </div>
                }
            </div>
        </nav>
    </header>

    <div class="container main-content-container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer text-muted border-top border-secondary border-opacity-10 py-4">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-translate text-primary"></i>
                    <span class="fw-bold text-white">WordApp</span>
                    <span class="text-secondary opacity-50">|</span>
                    <span>Spaced Repetition System</span>
                </div>
                <div>
                    <span>&copy; @DateTime.Now.Year - Kişisel Kelime Öğrenme Platformu</span>
                </div>
            </div>
        </div>
    </footer>

    <!-- Audio Player (Invisible, controlled globally via JS) -->
    <audio id="global-audio-player" style="display:none;"></audio>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
